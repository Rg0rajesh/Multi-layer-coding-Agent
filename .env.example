# .env.example — copy to .env and fill in real values
POSTGRES_PASSWORD=change_me
JWT_SECRET_KEY=generate_a_64_char_random_string

# Local LLM — 3B tag keeps this runnable on laptop RAM/VRAM (~4GB vs 8+GB for 7B).
# Bump to qwen2.5-coder:7b here (and in the ollama-init pull) if you move to
# a machine with more headroom — nothing else in the codebase needs to change.
OLLAMA_MODEL=qwen2.5-coder:3b
LLAMA_GUARD_MODEL=llama-guard3

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# optional
SENDGRID_API_KEY=
SLACK_WEBHOOK_URL=
